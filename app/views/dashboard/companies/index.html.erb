<div class="page-header">
  <h1 class="page-title">Companies</h1>
  <p class="page-subtitle">Browse listed companies</p>
</div>

<div class="section-card">
  <div class="company-search"
       data-controller="company-search"
       data-company-search-url-value="<%= dashboard_companies_path %>">
    <form class="company-search__form" data-action="submit->company-search#submit">
      <input type="text"
             class="form-input company-search__input"
             placeholder="証券コード・企業名で検索..."
             data-company-search-target="input"
             data-action="input->company-search#search">
      <button type="submit" class="btn btn-primary">検索</button>
      <span class="company-search__loading" data-company-search-target="loading" hidden>検索中...</span>
    </form>
  </div>
</div>

<turbo-frame id="company_list">
  <%= render "dashboard/companies/company_list", companies: @companies %>
</turbo-frame>
