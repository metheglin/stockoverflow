<dialog class="preset-save-dialog" data-preset-manager-target="saveDialog">
  <div class="dialog-content">
    <div class="dialog-header">
      <h3 class="dialog-title">プリセットを保存</h3>
      <button class="btn-icon" data-action="preset-manager#closeSaveModal">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="dialog-body">
      <div class="form-group">
        <label class="form-label" for="preset_name">名前 <span class="required">*</span></label>
        <input type="text" id="preset_name" class="form-input"
               data-preset-manager-target="presetName"
               placeholder="例: 高ROE連続増収銘柄">
      </div>
      <div class="form-group">
        <label class="form-label" for="preset_description">説明</label>
        <textarea id="preset_description" class="form-input"
                  data-preset-manager-target="presetDescription"
                  rows="2"
                  placeholder="任意で説明を入力"></textarea>
      </div>
    </div>
    <div class="dialog-footer">
      <button class="btn" data-action="preset-manager#closeSaveModal">キャンセル</button>
      <button class="btn btn-primary" data-action="preset-manager#savePreset">保存</button>
    </div>
  </div>
</dialog>
