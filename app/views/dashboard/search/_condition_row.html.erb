<div class="condition-row" data-filter-builder-target="conditionRow">
  <div class="condition-row-fields">
    <%# Condition type selector %>
    <select class="form-select form-select-sm condition-type-select"
            data-action="change->filter-builder#changeConditionType">
      <option value="">-- 種類を選択 --</option>
      <% condition_type_options.each do |label, value| %>
        <option value="<%= value %>"><%= label %></option>
      <% end %>
    </select>

    <%# Field selector (populated dynamically based on type) %>
    <select class="form-select form-select-sm condition-field-select"
            data-action="change->filter-builder#changeField"
            style="display:none;">
      <option value="">-- 指標を選択 --</option>
    </select>

    <%# Value inputs: metric_range / data_json_range %>
    <div class="condition-value-inputs condition-range-inputs" style="display:none;">
      <input type="number" step="any" class="form-input form-input-sm condition-min"
             placeholder="最小値">
      <span class="condition-separator">~</span>
      <input type="number" step="any" class="form-input form-input-sm condition-max"
             placeholder="最大値">
    </div>

    <%# Value inputs: metric_boolean %>
    <div class="condition-value-inputs condition-boolean-inputs" style="display:none;">
      <select class="form-select form-select-sm condition-boolean-value">
        <option value="true">はい</option>
        <option value="false">いいえ</option>
      </select>
    </div>

    <%# Value inputs: company_attribute %>
    <div class="condition-value-inputs condition-attribute-inputs" style="display:none;">
      <input type="text" class="form-input form-input-sm condition-attribute-value"
             placeholder="値をカンマ区切りで入力">
    </div>

    <%# Value inputs: trend_filter %>
    <div class="condition-value-inputs condition-trend-inputs" style="display:none;">
      <select class="form-select form-select-sm condition-trend-value">
        <option value="">-- トレンドを選択 --</option>
        <% trend_label_options.each do |label, value| %>
          <option value="<%= value %>"><%= label %></option>
        <% end %>
      </select>
    </div>

    <%# Value inputs: temporal %>
    <div class="condition-value-inputs condition-temporal-inputs" style="display:none;">
      <select class="form-select form-select-sm condition-temporal-type"
              data-action="change->filter-builder#changeTemporalType">
        <option value="">-- 条件種別 --</option>
        <% temporal_type_options.each do |label, value| %>
          <option value="<%= value %>"><%= label %></option>
        <% end %>
      </select>

      <div class="temporal-threshold-group condition-temporal-sub-inputs" style="display:none;">
        <select class="form-select form-select-sm condition-temporal-comparison">
          <option value="gte">以上</option>
          <option value="lte">以下</option>
          <option value="gt">超</option>
          <option value="lt">未満</option>
        </select>
        <input type="number" step="any" class="form-input form-input-sm condition-temporal-threshold"
               placeholder="閾値">
      </div>

      <div class="temporal-n-group condition-temporal-sub-inputs" style="display:none;">
        <input type="number" step="1" min="1" class="form-input form-input-sm condition-temporal-n"
               placeholder="N期">
      </div>

      <div class="temporal-m-group condition-temporal-sub-inputs" style="display:none;">
        <span class="condition-separator">/</span>
        <input type="number" step="1" min="1" class="form-input form-input-sm condition-temporal-m"
               placeholder="M期中">
      </div>
    </div>
  </div>

  <%# Remove button %>
  <button class="btn btn-sm btn-icon condition-remove-btn"
          data-action="filter-builder#removeCondition"
          title="この条件を削除">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="18" y1="6" x2="6" y2="18"></line>
      <line x1="6" y1="6" x2="18" y2="18"></line>
    </svg>
  </button>
</div>
