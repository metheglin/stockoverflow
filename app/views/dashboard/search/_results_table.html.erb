<div class="section-card" data-controller="result-table">
  <div class="card-header">
    <h2 class="card-title">検索結果</h2>
    <span class="results-count"><%= results.size %>件</span>
  </div>

  <% if results.any? %>
    <div class="table-container">
      <table class="table table-striped table-compact">
        <thead>
          <tr>
            <% display_columns.each do |col| %>
              <th class="<%= 'cell-numeric' if numeric_column?(col) %>">
                <%= column_label(col) %>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody>
          <% results.each do |result| %>
            <% company = result[:company] %>
            <% metric = result[:metric] %>
            <tr class="row-clickable"
                data-action="click->result-table#navigateToCompany"
                data-company-id="<%= company.id %>">
              <% display_columns.each do |col| %>
                <% value = get_result_value(company, metric, col) %>
                <td class="<%= 'cell-numeric' if numeric_column?(col) %> <%= value_color_class(value) if numeric_column?(col) && value.is_a?(Numeric) %>">
                  <% if numeric_column?(col) %>
                    <%= format_metric_value(value, col) %>
                  <% else %>
                    <%= value %>
                  <% end %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p class="text-secondary text-center">条件に一致する企業が見つかりませんでした</p>
  <% end %>
</div>
